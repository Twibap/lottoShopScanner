# Copy to .env.server.mac and replace every placeholder.
POSTGRES_DB=lotto
POSTGRES_USER=lotto
# Use a long URL-safe value (letters, numbers, hyphen, underscore) because it is
# embedded in DATABASE_URL by compose.mac-server.yaml.
POSTGRES_PASSWORD=replace-with-a-long-url-safe-password

BACKEND_PORT=8000
WEB_CONCURRENCY=1

# Public HTTPS endpoint. Forward router TCP 80 and TCP/UDP 443 to this Mac.
API_DOMAIN=api.example.com

# Optional. Leave blank when NAVER address geocoding is not used.
NAVER_GEOCODE_CLIENT_ID=
NAVER_GEOCODE_CLIENT_SECRET=
