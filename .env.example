# Local Docker Compose settings.
POSTGRES_DB=lotto
POSTGRES_USER=lotto
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_PORT=5432
BACKEND_PORT=8000

# NAVER Cloud credentials used by the backend address geocoding fallback.
NAVER_GEOCODE_CLIENT_ID=replace-with-naver-client-id
NAVER_GEOCODE_CLIENT_SECRET=replace-with-naver-client-secret

# Flutter build-time values. Pass these with --dart-define when building apps.
NAVER_MAP_CLIENT_ID=replace-with-naver-map-client-id
API_BASE_URL=https://replace-with-test-backend.example.com
SUPPORT_EMAIL=support@example.com
